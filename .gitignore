# Python: standard .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
docs/*
# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/
wheelhouse/

# Virtual environments
venv/
ENV/
env/
.env/
.venv/
env.bak/
venv.bak/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Translations
*.mo
*.pot

# Django / common local files
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/

# Sphinx / docs build
docs/_build/
.build/
.docs/

# Type checkers / caches
.pyre/
.mypy_cache/
.dmypy.json

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# dotenv
.env
.env.*

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# Coverage / test reports
coverage.xml
nosetests.xml

# Jupyter
.ipynb_checkpoints

# Custom: ignore .antigravitycli folder
.antigravitycli/

data/*